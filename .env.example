# McpVanguard — Configuration Reference
# Copy to .env and fill in your values.

# ─── Core ──────────────────────────────────────────────────────────────────
VANGUARD_LOG_LEVEL=INFO
VANGUARD_LOG_FILE=audit.log
VANGUARD_RULES_DIR=rules

# ─── SSE Authentication (RECOMMENDED) ──────────────────────────────────────
# Set this to protect your SSE bridge. Clients must send in the X-Api-Key header.
VANGUARD_API_KEY=your-secret-api-key-here

# ─── Layer 2: Semantic Intelligence ────────────────────────────────────────
VANGUARD_SEMANTIC_ENABLED=false
VANGUARD_OLLAMA_URL=http://localhost:11434
VANGUARD_OLLAMA_MODEL=phi4-mini
VANGUARD_SEMANTIC_THRESHOLD_BLOCK=0.80
VANGUARD_SEMANTIC_THRESHOLD_WARN=0.50

# ─── Optional: OpenAI Semantic Backend ───────────────────────────────────
# VANGUARD_OPENAI_API_KEY=your-openai-key
# VANGUARD_OPENAI_MODEL=gpt-4o-mini
# VANGUARD_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Optional: Universal Cloud Provider (DeepSeek, Groq, Mistral) ────────
# Custom OpenAI-compatible endpoints.
# VANGUARD_SEMANTIC_CUSTOM_KEY=your-api-key
# VANGUARD_SEMANTIC_CUSTOM_MODEL=deepseek-chat
# VANGUARD_SEMANTIC_CUSTOM_URL=https://api.deepseek.com/v1

# ─── Optional: MiniMax Semantic Backend ──────────────────────────────────
# VANGUARD_MINIMAX_API_KEY=your-minimax-key
# VANGUARD_MINIMAX_MODEL=MiniMax-M2.5
# VANGUARD_MINIMAX_BASE_URL=https://api.minimax.io/v1

# ─── Layer 3: Behavioral Analysis ──────────────────────────────────────────
VANGUARD_BEHAVIORAL_ENABLED=true
VANGUARD_BEH_READ_LIMIT=50
VANGUARD_BEH_LIST_LIMIT=20

# ─── Optional: Redis (for distributed rate limiting) ───────────────────────
# VANGUARD_REDIS_URL=redis://localhost:6379

# ─── Optional: VEX Flight Recorder ─────────────────────────────────────────
# VANGUARD_VEX_URL=https://api.vexprotocol.com
# VANGUARD_VEX_KEY=your-agent-jwt

# ─── Advanced / Debug ──────────────────────────────────────────────────────
# Session TTL in seconds (default: 86400 = 24h)
# VANGUARD_SESSION_TTL=86400

# Set to 'true' to include detailed block reasons in JSON-RPC error responses.
# Leave 'false' (default) in production to avoid leaking rule internals.
# VANGUARD_EXPOSE_BLOCK_REASON=false
